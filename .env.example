# Template do ambiente de PRODUÇÃO.
# Copie para ".env" e preencha com os valores reais. NUNCA commitar o ".env" preenchido.

# Obrigatórias
DJANGO_SECRET_KEY=
DATABASE_URL=mysql://usuario:senha@host:3306/nome_do_banco
BOLETIM_PORT=8080

# Opcionais — só definir se precisar sobrescrever o padrão de produção
# (os valores abaixo são os defaults já usados quando a variável não existe)
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=localhost,192.168.1.10,atendimentocrur.cisbaf.org.br,www.atendimentocrur.cisbaf.org.br
# DJANGO_CORS_ALLOWED_ORIGINS=
# DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.10,https://atendimentocrur.cisbaf.org.br
