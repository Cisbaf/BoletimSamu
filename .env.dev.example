# Template do ambiente de DESENVOLVIMENTO.
# start-dev.sh copia este arquivo para ".env.dev" automaticamente se ele não existir.
# Nunca use estes valores em produção.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-dev-only-not-for-production
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Sem DATABASE_URL: usa SQLite local (django/src/db.sqlite3)
